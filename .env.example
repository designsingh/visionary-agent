# Cloudflare Browser Rendering (required for capture + scout)
# Create token: https://dash.cloudflare.com/profile/api-tokens with "Browser Rendering - Edit"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Gemini – Design Director (required for /api/generate-pitch)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: model id (default gemini-2.5-pro). Use gemini-3.1-pro-preview when available.
# GEMINI_MODEL=gemini-2.5-pro

# v0 Platform API (for BUILD step in generate-pitch)
# Get key: https://v0.dev/chat/settings/keys
V0_API_KEY=
