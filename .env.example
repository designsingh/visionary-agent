# Cloudflare Browser Rendering (required for scout)
# Create token: https://dash.cloudflare.com/profile/api-tokens with "Browser Rendering - Edit"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# v0 Platform API (for redesign step – optional for scout-only)
# Get key: https://v0.dev/chat/settings/keys
V0_API_KEY=
