{
  "name": "visionary-agent",
  "version": "0.1.0",
  "description": "Autonomous design scout: analyze sites via Cloudflare /json, redesign with v0, side-by-side comparison.",
  "type": "module",
  "scripts": {
    "scout": "tsx src/scout.ts",
    "scrape": "tsx scripts/scrape-site.ts",
    "compare": "tsx src/compare.ts",
    "ui": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "build:scraper": "cd scraper-ui && npm install && npm run build",
    "build": "tsc",
    "dev": "tsx watch src/scout.ts"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "cloudflare": "^5.2.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.1",
    "sharp": "^0.33.5",
    "v0-sdk": "^0.16.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
